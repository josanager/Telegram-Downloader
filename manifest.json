{
  "manifest_version": 3,
  "name": "Misil - Telegram Downloader",
  "version": "2.1.0",
  "description": "High-speed media downloader for Telegram Web. Save protected videos and images directly to your Downloads folder.",
  "minimum_chrome_version": "114",
  "permissions": [
    "activeTab",
    "downloads",
    "offscreen",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "*://web.telegram.org/*",
    "*://cqgpbmxcavdvcvcoojyi.supabase.co/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "styles.css",
        "icons/logo.svg"
      ],
      "matches": [
        "*://web.telegram.org/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://web.telegram.org/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Misil"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}