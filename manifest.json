{
  "manifest_version": 3,
  "name": "Misil - Telegram Downloader",
  "version": "4.0.0",
  "description": "Download permitted media from Telegram Web with one click.",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://web.telegram.org/*",
    "https://cqgpbmxcavdvcvcoojyi.supabase.co/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "styles.css",
        "icons/miniatura.svg"
      ],
      "matches": ["https://web.telegram.org/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://web.telegram.org/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Misil"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}